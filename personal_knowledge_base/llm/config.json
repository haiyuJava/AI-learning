{
  "primary": "deepseek",
  "fallbacks": [
    "openai",
    "template"
  ],
  "providers": {
    "deepseek": {
      "type": "deepseek",
      "model": "deepseek-chat",
      "api_key_env": "DEEPSEEK_API_KEY",
      "base_url": "https://api.deepseek.com"
    },
    "openai": {
      "type": "openai",
      "model": "gpt-4.1-mini",
      "api_key_env": "OPENAI_API_KEY"
    }
  }
}
