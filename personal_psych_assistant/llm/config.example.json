{
  "primary": "openai",
  "fallbacks": ["deepseek", "template"],
  "providers": {
    "openai": {
      "type": "openai",
      "model": "gpt-4.1-mini",
      "api_key_env": "OPENAI_API_KEY"
    },
    "deepseek": {
      "type": "deepseek",
      "model": "deepseek-chat",
      "base_url": "https://api.deepseek.com",
      "api_key_env": "DEEPSEEK_API_KEY"
    },
    "template": {
      "type": "template"
    }
  }
}

